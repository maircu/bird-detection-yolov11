# 数据集（太大，不上传）
datasets/
archive/

# 输出文件（排除视频，保留图片和.gitkeep）
output/**/*.mp4
output/**/*.avi
output/**/*.mkv
结果/**/*.mp4
结果/**/*.avi
结果/**/*.mkv

# video和photo只保留.gitkeep，其他文件不上传
video/*
!video/.gitkeep
photo/*
!photo/.gitkeep

# Python缓存
__pycache__/
*.pyc
*.pyo
.venv/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# 临时文件
_archive/

# 报告文件
报告/
可视化/
引文/

# 训练结果：忽略所有runs（best.pt通过force add上传）
runs/

